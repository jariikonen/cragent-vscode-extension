{
  "compilerOptions": {
    "strict": true,
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "out",
    "rootDir": "src",
    "lib": ["ES2020"],
    "moduleResolution": "node",
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@modelcontextprotocol/sdk/client": ["./node_modules/@modelcontextprotocol/sdk/dist/cjs/client/index.d.ts"],
      "@modelcontextprotocol/sdk/client/streamableHttp": ["./node_modules/@modelcontextprotocol/sdk/dist/cjs/client/streamableHttp.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "out", "test"]
}
